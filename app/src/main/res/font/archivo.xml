<?xml version="1.0" encoding="utf-8"?>
<!--
  Archivo (sans) — UI: labels, buttons, eyebrows, verse numbers, nav, meta.
  Reference as @font/archivo. Same weight-selection notes as spectral.xml.
-->
<font-family xmlns:app="http://schemas.android.com/apk/res-auto">
    <font app:fontStyle="normal" app:fontWeight="400" app:font="@font/archivo_regular" />
    <font app:fontStyle="normal" app:fontWeight="500" app:font="@font/archivo_medium" />
    <font app:fontStyle="normal" app:fontWeight="600" app:font="@font/archivo_semibold" />
    <font app:fontStyle="normal" app:fontWeight="700" app:font="@font/archivo_bold" />
</font-family>
