<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ========================================================= -->
    <!-- DEFAULT (DAY) = LIGHT THEME: "Sunrise Orange"             -->
    <!-- These values are used whenever the device is NOT in       -->
    <!-- night mode. The night-mode versions live in               -->
    <!-- res/values-night/colors.xml and use the SAME names so     -->
    <!-- every layout swaps automatically.                         -->
    <!-- ========================================================= -->
    <color name="bg_primary">#FFF7ED</color>     <!-- warm cream app background -->
    <color name="bg_header">#FFFFFF</color>      <!-- white top/bottom bars -->
    <color name="bg_surface">#FFFFFF</color>     <!-- white cards (Genesis card, notes) -->
    <color name="text_primary">#292524</color>  <!-- warm charcoal (softer than black) -->
    <color name="text_secondary">#78716C</color><!-- muted warm grey -->
    <color name="accent_red">#F97316</color>     <!-- punchy sunrise orange -->
    <color name="nav_ripple">#40F97316</color>  <!-- translucent orange ripple for tabs -->
</resources>