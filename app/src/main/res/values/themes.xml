<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MBible" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bg_surface</item>
        <item name="colorPrimaryVariant">@color/bg_header</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="bottomNavigationStyle">@style/NavStyle</item>
    </style>

    <!-- ===================== BOTTOM NAV (Scriptorium) ===================== -->
    <!-- Active item now gets an accent_soft pill behind the icon (Material
         "active indicator"), and icon+label switch to accent via the
         nav_item_color selector. Labels use Archivo. -->
    <style name="NavStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_header</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemRippleColor">@color/nav_ripple</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemActiveIndicatorStyle">@style/Nav.ActiveIndicator</item>
        <item name="itemTextAppearanceActive">@style/Nav.Label</item>
        <item name="itemTextAppearanceInactive">@style/Nav.Label</item>
    </style>

    <!-- The accent_soft pill behind the selected tab's icon. -->
    <style name="Nav.ActiveIndicator" parent="">
        <item name="android:color">@color/accent_soft</item>
        <item name="android:width">62dp</item>
        <item name="android:height">34dp</item>
        <item name="marginHorizontal">10dp</item>
        <item name="shapeAppearance">@style/Nav.Indicator.Shape</item>
    </style>

    <style name="Nav.Indicator.Shape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Nav.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/archivo_semibold</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- ===================== DIALOGS (unchanged) ===================== -->
    <style name="ThemeOverlay.MBible.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="colorPrimary">@color/accent_red</item>
        <item name="buttonBarPositiveButtonStyle">@style/MBible.Dialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/MBible.Dialog.Button</item>
    </style>

    <style name="MBible.Dialog.Button" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent_red</item>
    </style>
</resources>
