<?xml version="1.0" encoding="utf-8"?>
<!-- Active tab = accent; inactive = muted tertiary. Drives both icon tint and label. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:color="@color/accent_red" />
    <item android:color="@color/text_tertiary" />
</selector>
