<?xml version="1.0" encoding="utf-8"?>
<!-- Active / open pill: accent_soft fill + accent stroke, fully round.
     Swap a view's background to this for the "open" translation picker
     or an active tab pill. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/accent_soft" />
    <corners android:radius="999dp" />
    <stroke android:width="1dp" android:color="@color/accent_red" />
</shape>
