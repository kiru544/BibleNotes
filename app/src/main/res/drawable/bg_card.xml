<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded card: bg_surface fill + 1dp hairline border, radius 16dp.
     For the "very soft shadow", set android:elevation="2dp" on the view
     (a shape drawable can't cast a shadow by itself). Or use a
     MaterialCardView with app:cardCornerRadius="16dp", app:strokeWidth="1dp",
     app:strokeColor="@color/hairline", app:cardElevation="2dp". -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/bg_surface" />
    <corners android:radius="16dp" />
    <stroke android:width="1dp" android:color="@color/hairline" />
</shape>
