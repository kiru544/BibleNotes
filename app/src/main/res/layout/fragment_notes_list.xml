<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Masthead with New button at right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:paddingTop="22dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◆ YOUR JOURNAL"
                android:textAppearance="@style/TextAppearance.Scriptorium.Eyebrow" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Notes"
                android:textAppearance="@style/TextAppearance.Scriptorium.ScreenTitle" />
        </LinearLayout>

        <Button
            android:id="@+id/btnNewNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ New"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:fontFamily="@font/archivo_semibold"
            android:textColor="@color/on_accent"
            android:minWidth="0dp"
            android:paddingHorizontal="18dp"
            app:backgroundTint="@color/accent_red"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- Notes list (cards float on the page; no surface box) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/notesRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:clipToPadding="false" />

    <!-- Bottom action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:paddingVertical="10dp">

        <Button
            android:id="@+id/btnExportNotes"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Export"
            android:textAllCaps="false"
            android:fontFamily="@font/archivo_semibold"
            android:textColor="@color/text_secondary"
            app:strokeColor="@color/hairline"
            app:cornerRadius="12dp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnImportNotes"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Import"
            android:textAllCaps="false"
            android:fontFamily="@font/archivo_semibold"
            android:textColor="@color/text_secondary"
            app:strokeColor="@color/hairline"
            app:cornerRadius="12dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnAliasSettings"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_shorten_names"
            android:tint="@color/text_secondary"
            android:background="@drawable/icon_button_bg"
            android:padding="11dp"
            android:contentDescription="Alias Settings" />
    </LinearLayout>

</LinearLayout>
