<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="12dp">

    <Button
        android:id="@+id/btnNewNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New note" />

    <!-- Notes list with box -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/notesRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/bg_surface"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Bottom action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnExportNotes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Export"
            android:layout_marginEnd="4dp"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btnImportNotes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Import"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:textAllCaps="false"/>

        <ImageButton
            android:id="@+id/btnAliasSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="0"
            android:src="@drawable/ic_shorten_names"
            android:tint="@color/text_secondary"
            android:background="@drawable/borderless_accent_ripple"
            android:padding="8dp"
            android:layout_marginStart="8dp"
            android:layout_gravity="center_vertical"
            android:contentDescription="Alias Settings"/>

    </LinearLayout>

</LinearLayout>