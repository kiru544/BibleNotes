<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Header row: translation pill (centered) + icon theme toggle (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="8dp">

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/translationPicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="18dp"
            android:paddingVertical="7dp"
            android:text="KJV"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/archivo_semibold"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_pill"
            android:clickable="true"
            android:focusable="true" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <!-- Icon-only theme toggle (moon in light, sun in dark). -->
            <ImageButton
                android:id="@+id/btnThemeToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end|center_vertical"
                android:src="@drawable/ic_moon"
                android:background="@drawable/icon_button_bg"
                android:scaleType="centerInside"
                android:padding="9dp"
                android:contentDescription="Toggle theme" />
        </FrameLayout>
    </LinearLayout>

    <!-- Chapters / Verses masthead (editorial header). selectedBookTitle keeps its ID. -->
    <LinearLayout
        android:id="@+id/chaptersTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@color/bg_primary"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="◆ SCRIPTURE"
            android:textAppearance="@style/TextAppearance.Scriptorium.Eyebrow" />

        <TextView
            android:id="@+id/selectedBookTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.Scriptorium.ChapterTitle" />

        <!-- Fleuron rule -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/hairline" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◆"
                android:textColor="@color/accent_red"
                android:textSize="9sp"
                android:paddingHorizontal="10dp" />
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/hairline" />
        </LinearLayout>
    </LinearLayout>

    <!-- Book swiper -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/bookPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible"/>

    <!-- Book list -->
    <ListView
        android:id="@+id/bookList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@drawable/divider_hairline"
        android:dividerHeight="1dp"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:background="@color/bg_primary"
        android:visibility="gone"/>

    <!-- Chapters / Verses recycler -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chaptersRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="6dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <!-- Verses pager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/versePager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"/>

    <!-- Switch view button (accent). Kept as a Button (inflates as MaterialButton
         under the Material theme) so BibleFragment's `btnSwitchMode: Button` still
         casts. MaterialButton ignores android:background, so we tint instead. -->
    <Button
        android:id="@+id/btnSwitchMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/screen_padding_h"
        android:layout_marginVertical="12dp"
        android:text="Switch view"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:fontFamily="@font/archivo_semibold"
        android:textColor="@color/on_accent"
        app:backgroundTint="@color/accent_red"
        app:cornerRadius="12dp" />

</LinearLayout>
