<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/sheet_bg"
    android:paddingHorizontal="22dp"
    android:paddingTop="10dp"
    android:paddingBottom="24dp">

    <!-- drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="@drawable/sheet_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="◆ SCRIPTURE"
        android:textAppearance="@style/TextAppearance.Scriptorium.Eyebrow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/sheetReference"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.Scriptorium.ItemTitle"
            android:textSize="22sp" />

        <ImageButton
            android:id="@+id/sheetClose"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/icon_button_bg"
            android:padding="9dp"
            android:contentDescription="Close" />
    </LinearLayout>

    <!-- fleuron -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginVertical="10dp">
        <View android:layout_width="0dp" android:layout_height="1dp"
            android:layout_weight="1" android:background="@color/hairline" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="◆" android:textColor="@color/accent_red" android:textSize="9sp"
            android:paddingHorizontal="10dp" />
        <View android:layout_width="0dp" android:layout_height="1dp"
            android:layout_weight="1" android:background="@color/hairline" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="380dp"
        android:scrollbars="none">

        <TextView
            android:id="@+id/sheetVerses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/spectral_regular"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:lineSpacingMultiplier="1.7" />
    </ScrollView>
</LinearLayout>
