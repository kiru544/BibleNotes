<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_primary"
    android:padding="32dp">

    <!-- MaterialCardView IS-A CardView, so BookPagerAdapter's CardView cast still works,
         and we gain a hairline stroke. -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bookCard"
        android:layout_width="198dp"
        android:layout_height="268dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="6dp"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardElevation="3dp"
        app:strokeColor="@color/hairline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/bookImage"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="@color/text_tertiary"
                android:scaleType="centerInside"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/bookName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.Scriptorium.ScreenTitle"
        android:textSize="26sp" />

</LinearLayout>
